PORT=3000
# Ejemplo con autenticacion MongoDB habilitada:
# Si tu password tiene caracteres especiales (@, :, /, ?), codificala en URL.
MONGODB_URI=mongodb://<usuario_mongo>:<password_url_encoded>@127.0.0.1:27017/inhalex?authSource=inhalex
BACKUP_DIR=./backups
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=1d
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_WINDOW_MINUTES=15
AUTH_LOCK_MINUTES=15
AUTH_RATE_STALE_MINUTES=240
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
BACKUP_CLOUDINARY_CLOUD_NAME=
BACKUP_CLOUDINARY_API_KEY=
BACKUP_CLOUDINARY_API_SECRET=
